{
  "name": "tsconfig-doctor",
  "version": "0.0.1",
  "description": "Diagnose common tsconfig.json configuration problems.",
  "license": "MIT",
  "private": true,
  "author": "Epi Lo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Epi-1120/tsconfig-doctor.git"
  },
  "homepage": "https://github.com/Epi-1120/tsconfig-doctor",
  "bugs": {
    "url": "https://github.com/Epi-1120/tsconfig-doctor/issues"
  },
  "keywords": [
    "typescript",
    "tsconfig",
    "linter",
    "diagnostics",
    "cli",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "tsconfig-doctor": "dist/cli.js"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
